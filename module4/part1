#include <iostream>
using namespace std;

int main()
{
    
    int choice;

    cout << "Menu\n";
    cout << "1: A\n";
    cout << "2: B\n";
    cout << "3: C\n";
    cout << "Enter your choice: ";

    cin >> choice;

    if (choice == 1) {
    
        cout << "You chose A";
        
