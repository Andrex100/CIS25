#include <iostream>
#include "functions.h"

using namespace std;

int main()
{
    int userNumber;
    int choice;

    cout << "Enter your number: ";
    cin >> userNumber;

    cout << "Menu\n";
    cout << "1: Add 10\n";
    cout << "2: Divide by two\n";
    cout << "3: Multiply by two\n";
    cout << "Enter your choice: ";
    cin >> choice;

    if (choice == 1)

        optionA(userNumber);

    else if (choice == 2)

        optionB(userNumber);

    else if (choice == 3)

        optionC(userNumber);

    else
        cout << "Invalid choice.";

    return 0;
}
